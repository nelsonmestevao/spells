#!/usr/bin/env cached-nix-shell
#! nix-shell nix/shell/xonsh.nix -i xonsh
"""
Choose the desktop theme and applications' appearance based on that.

Usage:
  {program} [dark | light | status]
  {program} (-h | --help)
  {program} --version

Options:
  -h --help              Show this screen.
  -v --version           Show version.
"""

from docopt import docopt

import os
import sys

$RED="\033[1;31m"
$YELLOW="\033[1;33m"
$GREEN="\033[1;32m"
$BLUE="\033[1;34m"
$RESET="\033[0m"

# $RAISE_SUBPROC_ERROR = True

DOTFILES     = os.path.expandvars("$DOTFILES")
GIT_CONFIG   = f"{DOTFILES}/home/programs/git/gitconfig"

def pick_theme_interactively():
  return $(gum choose "dark" "light").strip()

def gsettings_get_color_scheme():
  return $(gsettings get org.gnome.desktop.interface color-scheme).strip().lower()

def get_current_theme():
  match gsettings_get_color_scheme():
    case "'prefer-dark'":
        return "dark"
    case "'default'":
        return "light"
    case _:
        return "¯\\_(ツ)_/¯"

def set_theme_to(theme):
  cfg = {
        "dark": {
            "gsettings_scheme": "prefer-dark",
            "git_delta_light":  "false"
        },
        "light": {
            "gsettings_scheme": "default",
            "git_delta_light":  "true"
        },
    }[theme]

  sed -i @(f"s/light =.*/light = {cfg['git_delta_light']}/g") @(GIT_CONFIG)
  gsettings set org.gnome.desktop.interface color-scheme @(cfg["gsettings_scheme"])

  echo -e @(f"{theme} mode activated") "$GREEN✓$RESET"

def main(args):
    if args["dark"]:
        set_theme_to("dark")
    elif args["light"]:
        set_theme_to("light")
    elif args["status"]:
        print(get_current_theme())
    else:
        theme = pick_theme_interactively()
        set_theme_to(theme)

if __name__ == "__main__":
    arguments = docopt(__doc__.format(program=__file__), version=f'{os.path.basename(__file__)} v0.1.0')

    main(arguments)

