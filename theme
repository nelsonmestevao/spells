#!/usr/bin/env nix-shell
#! nix-shell -I nixpkgs=channel:nixos-25.11
#! nix-shell -p gum python313 python313Packages.xonsh python313Packages.docopt
#! nix-shell -i xonsh
"""
Choose the desktop theme and applications' appearance based on that.

Usage:
  SCRIPT (dark | light)
  SCRIPT (-h | --help)
  SCRIPT --version

Options:
  -h --help              Show this screen.
  -v --version           Show version.
"""

from docopt import docopt

import os
import sys

$RED="\033[1;31m"
$YELLOW="\033[1;33m"
$GREEN="\033[1;32m"
$BLUE="\033[1;34m"
$RESET="\033[0m"

# $RAISE_SUBPROC_ERROR = True

def set_theme_to(theme):
  # declare -r alacritty_config="$DOTFILES/alacritty/alacritty.toml"
  # sed -i "s|^import = \[.*\]|import = [\"~/.dotfiles/alacritty/themes/google.${theme}.toml\"]|" "${alacritty_config}"
  git_config=os.path.expandvars("$DOTFILES/home/programs/git/gitconfig")

  match theme:
      case "dark":
        sed -i "s/light =.*/light = false/g" @(git_config)
        gsettings set org.gnome.desktop.interface color-scheme prefer-dark
      case "light":
        sed -i "s/light =.*/light = true/g" @(git_config)
        gsettings set org.gnome.desktop.interface color-scheme default

  echo -e @(f"{theme} mode activated") "$GREEN✓$RESET"

if __name__ == "__main__":
    arguments = docopt(__doc__.replace("SCRIPT", os.path.basename(sys.argv[0])), version="theme 0.1.0")

    if arguments["dark"]:
        set_theme_to("dark")
    elif arguments["light"]:
        set_theme_to("light")

