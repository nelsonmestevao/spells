#!/usr/bin/env cached-nix-shell
#! nix-shell -I nixpkgs=channel:nixos-25.11
#! nix-shell -p gum python313 python313Packages.xonsh python313Packages.docopt
#! nix-shell -i xonsh
"""
Manage spells.

Usage:
  {program} new [<name>]
  {program} edit [<name>]
  {program} (-h | --help)
  {program} --version

Commands:
  new       Create a new spell from a template.
  edit      Open an existing spell in the editor.

Options:
  -h --help              Show this screen.
  -v --version           Show version.
"""

from docopt import docopt

import os
import sys

# These are easy to use in bash commands.
$BLACK=$(tput setaf 0).strip()
$RED=$(tput setaf 1).strip()
$GREEN=$(tput setaf 2).strip()
$YELLOW=$(tput setaf 3).strip()
$BLUE=$(tput setaf 4).strip()
$MAGENTA=$(tput setaf 5).strip()
$CYAN=$(tput setaf 6).strip()
$WHITE=$(tput setaf 7).strip()
$PINK=$(tput setaf 13).strip()
$RESET=$(tput sgr0).strip()

# These are easy to use in python commands.
BLACK=$(tput setaf 0).strip()
RED=$(tput setaf 1).strip()
GREEN=$(tput setaf 2).strip()
YELLOW=$(tput setaf 3).strip()
BLUE=$(tput setaf 4).strip()
MAGENTA=$(tput setaf 5).strip()
CYAN=$(tput setaf 6).strip()
WHITE=$(tput setaf 7).strip()
PINK=$(tput setaf 13).strip()
RESET=$(tput sgr0).strip()


def success(msg):
    print(f"{msg} {GREEN}✓{RESET}")

def error(msg):
    print(f"{msg} {RED}✗{RESET}", file=sys.stderr)
    sys.exit(1)

def execute(title, cmd):
    if ![gum spin --align=right --title @(f"{title}...") --show-error -- @(cmd.split())]:
        success(title)
    else:
        error(title)

def log_warn(msg):
    print(f"{YELLOW}▲{RESET} {msg}", file=sys.stderr)

def log_info(msg):
    print(f"{BLUE}◆{RESET} {msg}")

def log_debug(msg):
    print(f"{PINK}●{RESET} {msg}")


SPELLS = os.path.expanduser("~/.spells")

TEMPLATE = '''#!/usr/bin/env cached-nix-shell
#! nix-shell -I nixpkgs=channel:nixos-25.11
#! nix-shell -p gum python313 python313Packages.xonsh python313Packages.docopt
#! nix-shell -i xonsh
"""
{description}

Usage:
  {{program}} [options]
  {{program}} (-h | --help)
  {{program}} --version

Options:
  -h --help              Show this screen.
  -v --version           Show version.
"""

from docopt import docopt

import os
import sys

# These are easy to use in bash commands.
$BLACK=$(tput setaf 0).strip()
$RED=$(tput setaf 1).strip()
$GREEN=$(tput setaf 2).strip()
$YELLOW=$(tput setaf 3).strip()
$BLUE=$(tput setaf 4).strip()
$MAGENTA=$(tput setaf 5).strip()
$CYAN=$(tput setaf 6).strip()
$WHITE=$(tput setaf 7).strip()
$PINK=$(tput setaf 13).strip()
$RESET=$(tput sgr0).strip()

# These are easy to use in python commands.
BLACK=$(tput setaf 0).strip()
RED=$(tput setaf 1).strip()
GREEN=$(tput setaf 2).strip()
YELLOW=$(tput setaf 3).strip()
BLUE=$(tput setaf 4).strip()
MAGENTA=$(tput setaf 5).strip()
CYAN=$(tput setaf 6).strip()
WHITE=$(tput setaf 7).strip()
PINK=$(tput setaf 13).strip()
RESET=$(tput sgr0).strip()


def success(msg):
    print(f"{{msg}} {{GREEN}}✓{{RESET}}")

def error(msg):
    print(f"{{msg}} {{RED}}✗{{RESET}}", file=sys.stderr)
    sys.exit(1)

def execute(title, cmd):
    if ![gum spin --align=right --title @(f"{{title}}...") --show-error -- @(cmd.split())]:
        success(title)
    else:
        error(title)

def log_warn(msg):
    print(f"{{YELLOW}}▲{{RESET}} {{msg}}", file=sys.stderr)

def log_info(msg):
    print(f"{{BLUE}}◆{{RESET}} {{msg}}")

def log_debug(msg):
    print(f"{{PINK}}●{{RESET}} {{msg}}")

def main(args):
    pass


if __name__ == "__main__":
    arguments = docopt(__doc__.format(program=__file__), version=f'{{os.path.basename(__file__)}} v0.1.0')

    main(arguments)

# vim: ft=python
'''

def pick_spell_name():
    return $(gum input --placeholder "Spell name").strip()

def pick_spell_interactively():
    spells = [f for f in os.listdir(SPELLS) if os.path.isfile(os.path.join(SPELLS, f)) and not f.startswith('.')]
    spells.sort()
    return $(gum filter @(spells)).strip()

def new_spell(name):
    if not name:
        name = pick_spell_name()

    if not name:
        error("No name provided.")

    path = os.path.join(SPELLS, name)

    if os.path.exists(path):
        error(f"Spell '{name}' already exists.")

    description = $(gum input --placeholder "Short description of the spell").strip()

    with open(path, 'w') as f:
        f.write(TEMPLATE.format(description=description or "TODO: describe this spell."))

    os.chmod(path, 0o755)
    success(f"Created spell '{name}'")

    $EDITOR @(path)

def edit_spell(name):
    if not name:
        name = pick_spell_interactively()

    if not name:
        error("No spell selected.")

    path = os.path.join(SPELLS, name)

    if not os.path.isfile(path):
        error(f"Spell '{name}' not found.")

    $EDITOR @(path)

def main(args):
    if args["new"]:
        new_spell(args["<name>"])
    elif args["edit"]:
        edit_spell(args["<name>"])

if __name__ == "__main__":
    arguments = docopt(__doc__.format(program=__file__), version=f'{os.path.basename(__file__)} v0.1.0')

    main(arguments)

