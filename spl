#!/usr/bin/env cached-nix-shell
#! nix-shell -I nixpkgs=channel:nixos-25.11
#! nix-shell -p gum python313 python313Packages.xonsh python313Packages.docopt
#! nix-shell -i xonsh
"""
Manage spells.

Usage:
  {program} new [<name>]
  {program} edit [<name>]
  {program} (-h | --help)
  {program} --version

Commands:
  new       Create a new spell from a template.
  edit      Open an existing spell in the editor.

Options:
  -h --help              Show this screen.
  -v --version           Show version.
"""

from docopt import docopt

import os
import sys

# These are easy to use in bash commands.
$RED="\033[1;31m"
$GREEN="\033[1;32m"
$YELLOW="\033[1;33m"
$BLUE="\033[1;34m"
$MAGENTA="\033[1;35m"
$CYAN="\033[1;36m"
$WHITE="\033[1;37m"
$RESET="\033[0m"

# These are easy to use in python commands.
RED="\033[1;31m"
GREEN="\033[1;32m"
YELLOW="\033[1;33m"
BLUE="\033[1;34m"
MAGENTA="\033[1;35m"
CYAN="\033[1;36m"
WHITE="\033[1;37m"
RESET="\033[0m"


def success(msg):
    print(f"{GREEN}✓{RESET} {msg}")

def error(msg):
    print(f"{RED}✗{RESET} {msg}", file=sys.stderr)
    sys.exit(1)

SPELLS = os.path.expanduser("~/.spells")

TEMPLATE = '''#!/usr/bin/env cached-nix-shell
#! nix-shell -I nixpkgs=channel:nixos-25.11
#! nix-shell -p gum python313 python313Packages.xonsh python313Packages.docopt
#! nix-shell -i xonsh
"""
{description}

Usage:
  {{program}} (-h | --help)
  {{program}} --version

Options:
  -h --help              Show this screen.
  -v --version           Show version.
"""

from docopt import docopt

import os
import sys

$RED="\\033[1;31m"
$GREEN="\\033[1;32m"
$YELLOW="\\033[1;33m"
$BLUE="\\033[1;34m"
$MAGENTA="\\033[1;35m"
$CYAN="\\033[1;36m"
$WHITE="\\033[1;37m"
$RESET="\\033[0m"

RED="\\033[1;31m"
GREEN="\\033[1;32m"
YELLOW="\\033[1;33m"
BLUE="\\033[1;34m"
MAGENTA="\\033[1;35m"
CYAN="\\033[1;36m"
WHITE="\\033[1;37m"
RESET="\\033[0m"


def success(msg):
    print(f"{{GREEN}}✓{{RESET}} {{msg}}")

def error(msg):
    print(f"{{RED}}✗{{RESET}} {{msg}}", file=sys.stderr)
    sys.exit(1)

def main(args):
    pass

if __name__ == "__main__":
    arguments = docopt(__doc__.format(program=__file__), version=f'{{os.path.basename(__file__)}} v0.1.0')

    main(arguments)

# vim: ft=python
'''

def pick_spell_name():
    return $(gum input --placeholder "Spell name").strip()

def pick_spell_interactively():
    spells = [f for f in os.listdir(SPELLS) if os.path.isfile(os.path.join(SPELLS, f)) and not f.startswith('.')]
    spells.sort()
    return $(gum filter @(spells)).strip()

def new_spell(name):
    if not name:
        name = pick_spell_name()

    if not name:
        error("No name provided.")

    path = os.path.join(SPELLS, name)

    if os.path.exists(path):
        error(f"Spell '{name}' already exists.")

    description = $(gum write --placeholder "Short description of the spell").strip()

    with open(path, 'w') as f:
        f.write(TEMPLATE.format(description=description or "TODO: describe this spell."))

    os.chmod(path, 0o755)
    success(f"Created spell '{name}'")

    $EDITOR @(path)

def edit_spell(name):
    if not name:
        name = pick_spell_interactively()

    if not name:
        error("No spell selected.")

    path = os.path.join(SPELLS, name)

    if not os.path.isfile(path):
        error(f"Spell '{name}' not found.")

    $EDITOR @(path)

def main(args):
    if args["new"]:
        new_spell(args["<name>"])
    elif args["edit"]:
        edit_spell(args["<name>"])

if __name__ == "__main__":
    arguments = docopt(__doc__.format(program=__file__), version=f'{os.path.basename(__file__)} v0.1.0')

    main(arguments)

# vim: ft=python
