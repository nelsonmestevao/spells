#!/usr/bin/env cached-nix-shell
#! nix-shell -I nixpkgs=channel:nixos-25.11
#! nix-shell -p deno
#! nix-shell -i bash
exec deno run - "$@" <<'DENO'
import QRCode from "npm:qrcode@1.5";

const args = Deno.args.filter(a => a !== "--large");
const large = Deno.args.includes("--large");
const url = args[0];
const opts = { type: "terminal", ...(large ? {} : { small: true }) };
const qr = await QRCode.toString(url, opts);
console.log(qr);
console.log(`\n${url}\n`);
DENO
