"""
Sync all branches with the main branch of remote repository.

Usage:
  {program} [options]
  {program} (-h | --help)
  {program} --version

Options:
  -h --help              Show this screen.
  -v --version           Show version.
  -r --remote=<remote>   Remote repository [default: origin].
  -b --branch=<branch>   Branch to sync [default: main].
"""
from docopt import docopt

import os
import re
import sys

# These are easy to use in bash commands.
$BLACK=$(tput setaf 0).strip()
$RED=$(tput setaf 1).strip()
$GREEN=$(tput setaf 2).strip()
$YELLOW=$(tput setaf 3).strip()
$BLUE=$(tput setaf 4).strip()
$MAGENTA=$(tput setaf 5).strip()
$CYAN=$(tput setaf 6).strip()
$WHITE=$(tput setaf 7).strip()
$PINK=$(tput setaf 13).strip()
$RESET=$(tput sgr0).strip()

# These are easy to use in python commands.
BLACK=$(tput setaf 0).strip()
RED=$(tput setaf 1).strip()
GREEN=$(tput setaf 2).strip()
YELLOW=$(tput setaf 3).strip()
BLUE=$(tput setaf 4).strip()
MAGENTA=$(tput setaf 5).strip()
CYAN=$(tput setaf 6).strip()
WHITE=$(tput setaf 7).strip()
PINK=$(tput setaf 13).strip()
RESET=$(tput sgr0).strip()

def success(msg):
    print(f"{msg} {GREEN}‚úì{RESET}")

def error(msg):
    print(f"{msg} {RED}‚úó{RESET}", file=sys.stderr)

def fail(msg):
    print(f"{msg} {RED}‚úó{RESET}", file=sys.stderr)
    sys.exit(1)

def execute(title, cmd):
    if ![gum spin --align=right --title @(f"{title}...") --show-error -- @(cmd.split())]:
        success(title)
    else:
        error(title)

def log_warn(msg):
    print(f"{YELLOW}‚ñ≤{RESET} {msg}", file=sys.stderr)

def log_info(msg):
    print(f"{BLUE}‚óÜ{RESET} {msg}")

def log_debug(msg):
    print(f"{PINK}‚óè{RESET} {msg}")

# $RAISE_SUBPROC_ERROR = True
def list_remotes():
    """
    List all configured git remotes.
    """
    return $(git remote).splitlines()

def list_branches():
    branches = $(git for-each-ref '--format=%(refname:short)' refs/heads).splitlines()
    return [b for b in branches if b not in {"main", "master", "develop", "dev"}]

if __name__ == "__main__":
    arguments = docopt(__doc__.format(program=os.path.basename(__file__)), version=f'{os.path.basename(__file__)} v0.1.0')
    remote_branch = arguments["--branch"]
    remote = arguments["--remote"]


    git checkout @(remote_branch)
    git fetch @(remote)

    for branch in list_branches():
        title = f"Checking out {branch}"

        if not ![gum spin --align=right --title=@(title) --show-error -- git checkout @(branch)]: 
            echo -e @(title) "$RED‚®Ø$RESET"
            continue

        if not ![gum spin --align=right --title=@(title) --show-error -- git rebase @(remote)/@(remote_branch)]:
            echo -e @(title) "$RED‚®Ø$RESET"
            break

        if not ![gum spin --align=right --title=@(title) --show-error -- git commit --verbose --no-edit --amend]:
            echo -e @(title) "$RED‚®Ø$RESET"
            break

        if not ![gum spin --align=right --title=@(title) --show-error -- git push --force-with-lease --force-if-includes]:
            echo -e @(title) "$RED‚®Ø$RESET"
            break

        echo -e @(title) "$GREEN‚úì$RESET"

