#!/usr/bin/env nix-shell
#! nix-shell -I nixpkgs=channel:nixos-25.11
#! nix-shell -p gum python313 python313Packages.xonsh python313Packages.docopt
#! nix-shell -i xonsh

$RED="\033[1;31m"
$YELLOW="\033[1;33m"
$GREEN="\033[1;32m"
$BLUE="\033[1;34m"
$RESET="\033[0m"

# $RAISE_SUBPROC_ERROR = True
def list_branches():
    branches = $(git for-each-ref '--format=%(refname:short)' refs/heads).splitlines()
    return [b for b in branches if b not in {"main", "master", "develop", "dev"}]

if __name__ == "__main__":
    git checkout main
    git fetch fork

    for branch in list_branches():
        title = f"Checking out {branch}"

        if not ![gum spin --align=right --title=@(title) --show-error -- git checkout @(branch)]: 
            echo -e @(title) "$RED⨯$RESET"
            continue

        if not ![gum spin --align=right --title=@(title) --show-error -- git rebase fork/main]:
            echo -e @(title) "$RED⨯$RESET"
            break

        if not ![gum spin --align=right --title=@(title) --show-error -- git commit --verbose --no-edit --amend]:
            echo -e @(title) "$RED⨯$RESET"
            break

        if not ![gum spin --align=right --title=@(title) --show-error -- git push --force-with-lease --force-if-includes]:
            echo -e @(title) "$RED⨯$RESET"
            break

        echo -e @(title) "$GREEN✓$RESET"

