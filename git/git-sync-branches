"""
Sync all branches with the main branch of remote repository.

Usage:
  {program} [options]
  {program} (-h | --help)
  {program} --version

Options:
  -h --help              Show this screen.
  -v --version           Show version.
  -r --remote=<remote>   Remote repository [default: origin].
  -b --branch=<branch>   Branch to sync [default: main].
"""

from docopt import docopt

import os
import re
import sys

# These are easy to use in bash commands.
$BLACK=$(tput setaf 0).strip()
$RED=$(tput setaf 1).strip()
$GREEN=$(tput setaf 2).strip()
$YELLOW=$(tput setaf 3).strip()
$BLUE=$(tput setaf 4).strip()
$MAGENTA=$(tput setaf 5).strip()
$CYAN=$(tput setaf 6).strip()
$WHITE=$(tput setaf 7).strip()
$PINK=$(tput setaf 13).strip()
$RESET=$(tput sgr0).strip()

# These are easy to use in python commands.
BLACK=$(tput setaf 0).strip()
RED=$(tput setaf 1).strip()
GREEN=$(tput setaf 2).strip()
YELLOW=$(tput setaf 3).strip()
BLUE=$(tput setaf 4).strip()
MAGENTA=$(tput setaf 5).strip()
CYAN=$(tput setaf 6).strip()
WHITE=$(tput setaf 7).strip()
PINK=$(tput setaf 13).strip()
RESET=$(tput sgr0).strip()


def success(msg):
    print(f"{msg} {GREEN}✓{RESET}")

def error(msg):
    print(f"{msg} {RED}✗{RESET}", file=sys.stderr)

def fail(msg):
    print(f"{msg} {RED}✗{RESET}", file=sys.stderr)
    sys.exit(1)

def execute(title, cmd):
    if execute_command(title, cmd):
        success(title)
        return True
    else:
        error(title)
        return False

def execute_command(title, cmd):
    return ![gum spin --align=right --title @(f"{title}...") --show-error -- @(cmd.split())]

def log_warn(msg):
    print(f"{YELLOW}▲{RESET} {msg}", file=sys.stderr)

def log_info(msg):
    print(f"{BLUE}◆{RESET} {msg}")

def log_debug(msg):
    print(f"{PINK}●{RESET} {msg}")

def list_worktree_branches():
    """
    Parse `git worktree list` output to get branches checked out in worktrees.
    """
    output = $(git worktree list).splitlines()
    branches = set()
    for line in output:
        match = re.match(r'^(\S+)\s+\S+\s+\[(.+)\]$', line)
        if match:
            branches.add(match.group(2))
    return branches

def list_branches():
    """
    List local branches, excluding principal and worktree branches.
    """
    worktree_branches = list_worktree_branches()
    principal = {"main", "master", "develop", "dev"}
    branches = $(git for-each-ref '--format=%(refname:short)' refs/heads).splitlines()
    return [b for b in branches if b not in principal and b not in worktree_branches]

def main(args):
    remote = args["--remote"]
    remote_branch = args["--branch"]

    execute(f"Fetching from {remote}", f"git fetch {remote}")

    execute(f"Checking out {remote_branch}", f"git checkout {remote_branch}")
    branches = list_branches()

    if not branches:
        log_warn("No branches found to sync")
        return

    log_info(f"Found {len(branches)} branch{'es' if len(branches) != 1 else ''} ({', '.join(branches)}) to sync")


    for branch in branches:
        title = f"Syncing {branch}"

        if not execute_command(title, f"git checkout {branch}"):
            error(f"Failed to checkout {branch}")
            continue

        if not execute_command(title, f"git rebase {remote}/{remote_branch}"):
            error(f"Failed to rebase {branch} onto {remote}/{remote_branch}")
            execute(f"Aborting rebase for {branch}", "git rebase --abort")
            continue

        if not execute_command(title, "git push --force-with-lease --force-if-includes"):
            error(f"Failed to push {branch}")
            continue

        success(title)

if __name__ == "__main__":
    arguments = docopt(__doc__.format(program=__file__), version=f'{os.path.basename(__file__)} v0.1.0')

    main(arguments)

